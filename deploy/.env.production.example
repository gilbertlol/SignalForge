# Copy to /opt/signalforge/shared/.env on the server and replace every placeholder.
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=signalforge.dev2share.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://signalforge.dev2share.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
SIGNALFORGE_CREDENTIAL_KEY=replace-with-a-separate-long-random-value

# Keep these only for the first deployment. Remove them after the owner is created.
SIGNALFORGE_OWNER_EMAIL=owner@example.com
SIGNALFORGE_OWNER_PASSWORD=replace-with-at-least-12-characters

POSTGRES_DB=signalforge
POSTGRES_USER=signalforge
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_DB=1
CELERY_RESULT_BACKEND_DB=2

# Keep `edge` for built-in Caddy HTTPS. Leave blank when an existing host
# reverse proxy terminates TLS and forwards to 127.0.0.1:8000.
COMPOSE_PROFILES=edge
SIGNALFORGE_APP_PORT=8000
